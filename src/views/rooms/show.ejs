<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi Tiết Phòng</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/nav') %>

    <div class="main-content">
        <div class="container">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-between align-center">
                        <h2>🚪 Chi Tiết Phòng <%= room.room_number %></h2>
                        <div class="d-flex gap-2">
                            <a href="/rooms/<%= room.room_id %>/edit" class="btn btn-warning">Sửa</a>
                            <a href="/rooms" class="btn btn-secondary">Quay Lại</a>
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                    <div>
                        <h3 class="mb-2">Thông Tin Phòng</h3>
                        <table style="width: 100%;">
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Số Phòng:</td>
                                <td style="padding: 0.5rem;"><%= room.room_number %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Loại Phòng:</td>
                                <td style="padding: 0.5rem;"><%= room.type_name %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Tầng:</td>
                                <td style="padding: 0.5rem;">Tầng <%= room.floor %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Giá:</td>
                                <td style="padding: 0.5rem;"><%= formatCurrency(room.base_price) %>/đêm</td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Sức Chứa:</td>
                                <td style="padding: 0.5rem;"><%= room.max_occupancy %> người</td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Trạng Thái:</td>
                                <td style="padding: 0.5rem;">
                                    <% if (room.status === 'available') { %>
                                        <span class="badge badge-success">Trống</span>
                                    <% } else if (room.status === 'occupied') { %>
                                        <span class="badge badge-danger">Đang thuê</span>
                                    <% } else if (room.status === 'reserved') { %>
                                        <span class="badge badge-warning">Đã đặt</span>
                                    <% } else if (room.status === 'maintenance') { %>
                                        <span class="badge badge-secondary">Bảo trì</span>
                                    <% } %>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold; vertical-align: top;">Mô Tả:</td>
                                <td style="padding: 0.5rem;"><%= room.description || 'Không có' %></td>
                            </tr>
                        </table>
                    </div>

                    <div>
                        <h3 class="mb-2">Thông Tin Loại Phòng</h3>
                        <p><%= room.type_description || 'Không có mô tả' %></p>

                        <% if (room.status === 'available') { %>
                            <div class="mt-3">
                                <a href="/bookings/create?room_id=<%= room.room_id %>" class="btn btn-primary">
                                    Đặt Phòng Này
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
