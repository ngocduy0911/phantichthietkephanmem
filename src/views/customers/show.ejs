<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi Tiết Khách Hàng</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/nav') %>

    <div class="main-content">
        <div class="container">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-between align-center">
                        <h2>👤 Chi Tiết Khách Hàng</h2>
                        <div class="d-flex gap-2">
                            <a href="/bookings/create?customer_id=<%= customer.customer_id %>" class="btn btn-success">Đặt Phòng</a>
                            <a href="/customers/<%= customer.customer_id %>/edit" class="btn btn-warning">Sửa</a>
                            <a href="/customers" class="btn btn-secondary">Quay Lại</a>
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                    <div>
                        <h3 class="mb-2">Thông Tin Cá Nhân</h3>
                        <table style="width: 100%;">
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Họ Tên:</td>
                                <td style="padding: 0.5rem;"><%= customer.full_name %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">CMND/CCCD:</td>
                                <td style="padding: 0.5rem;"><%= customer.id_card %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Số Điện Thoại:</td>
                                <td style="padding: 0.5rem;"><%= customer.phone %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Email:</td>
                                <td style="padding: 0.5rem;"><%= customer.email || 'Không có' %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Địa Chỉ:</td>
                                <td style="padding: 0.5rem;"><%= customer.address || 'Không có' %></td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Ngày Sinh:</td>
                                <td style="padding: 0.5rem;">
                                    <%= customer.date_of_birth ? moment(customer.date_of_birth).format('DD/MM/YYYY') : 'Không có' %>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 0.5rem; font-weight: bold;">Quốc Tịch:</td>
                                <td style="padding: 0.5rem;"><%= customer.nationality || 'Không có' %></td>
                            </tr>
                        </table>
                    </div>

                    <div>
                        <h3 class="mb-2">Thống Kê</h3>
                        <div class="stat-card" style="margin-bottom: 1rem;">
                            <h3>Tổng Số Lần Đặt Phòng</h3>
                            <div class="stat-value"><%= bookingHistory.length %></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h2>📅 Lịch Sử Đặt Phòng</h2>
                </div>

                <% if (bookingHistory.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Mã Booking</th>
                                    <th>Phòng</th>
                                    <th>Loại Phòng</th>
                                    <th>Check-in</th>
                                    <th>Check-out</th>
                                    <th>Tổng Tiền</th>
                                    <th>Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bookingHistory.forEach(booking => { %>
                                    <tr>
                                        <td>#<%= booking.booking_id %></td>
                                        <td><%= booking.room_number %></td>
                                        <td><%= booking.type_name %></td>
                                        <td><%= moment(booking.check_in_date).format('DD/MM/YYYY') %></td>
                                        <td><%= moment(booking.check_out_date).format('DD/MM/YYYY') %></td>
                                        <td><%= formatCurrency(booking.total_price) %></td>
                                        <td>
                                            <% if (booking.status === 'pending') { %>
                                                <span class="badge badge-warning">Chờ xác nhận</span>
                                            <% } else if (booking.status === 'confirmed') { %>
                                                <span class="badge badge-info">Đã xác nhận</span>
                                            <% } else if (booking.status === 'checked_in') { %>
                                                <span class="badge badge-success">Đã nhận phòng</span>
                                            <% } else if (booking.status === 'checked_out') { %>
                                                <span class="badge badge-secondary">Đã trả phòng</span>
                                            <% } else if (booking.status === 'cancelled') { %>
                                                <span class="badge badge-danger">Đã hủy</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-center" style="padding: 2rem; color: #7f8c8d;">
                        Khách hàng chưa có lịch sử đặt phòng.
                    </p>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
