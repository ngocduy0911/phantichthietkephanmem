<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tạo Hóa Đơn</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/nav') %>

    <div class="main-content">
        <div class="container">
            <div class="card">
                <div class="card-header">
                    <h2>💳 Tạo Hóa Đơn</h2>
                </div>

                <% if (error) { %>
                    <div class="alert alert-error">
                        <%= error %>
                    </div>
                <% } %>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
                    <div>
                        <h3 class="mb-2">Thông Tin Khách Hàng</h3>
                        <p><strong>Họ Tên:</strong> <%= booking.full_name %></p>
                        <p><strong>CMND:</strong> <%= booking.id_card %></p>
                        <p><strong>SĐT:</strong> <%= booking.phone %></p>
                    </div>
                    <div>
                        <h3 class="mb-2">Thông Tin Booking</h3>
                        <p><strong>Phòng:</strong> <%= booking.room_number %> - <%= booking.type_name %></p>
                        <p><strong>Check-in:</strong> <%= moment(booking.check_in_date).format('DD/MM/YYYY') %></p>
                        <p><strong>Check-out:</strong> <%= moment(booking.check_out_date).format('DD/MM/YYYY') %></p>
                    </div>
                </div>

                <h3 class="mb-2">Chi Tiết Hóa Đơn</h3>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Mô Tả</th>
                            <th>Đơn Giá</th>
                            <th>Số Lượng</th>
                            <th>Thành Tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Tiền Phòng (<%= booking.type_name %>)</td>
                            <td><%= formatCurrency(booking.base_price) %>/đêm</td>
                            <td><%= Math.ceil((new Date(booking.check_out_date) - new Date(booking.check_in_date)) / (1000 * 60 * 60 * 24)) %> đêm</td>
                            <td><%= formatCurrency(roomCharge) %></td>
                        </tr>
                        <% if (bookingServices.length > 0) { %>
                            <% bookingServices.forEach(service => { %>
                                <tr>
                                    <td><%= service.service_name %></td>
                                    <td><%= formatCurrency(service.price) %>/<%= service.unit %></td>
                                    <td><%= service.quantity %></td>
                                    <td><%= formatCurrency(service.total_price) %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                        <tr>
                            <td colspan="3" style="text-align: right;"><strong>Tổng Tiền Dịch Vụ:</strong></td>
                            <td><strong><%= formatCurrency(serviceCharge) %></strong></td>
                        </tr>
                        <tr>
                            <td colspan="3" style="text-align: right;"><strong>Thuế VAT (10%):</strong></td>
                            <td><strong><%= formatCurrency(tax) %></strong></td>
                        </tr>
                        <tr style="background-color: #f8f9fa;">
                            <td colspan="3" style="text-align: right; font-size: 1.1rem;"><strong>TỔNG CỘNG:</strong></td>
                            <td style="font-size: 1.2rem; color: #27ae60;"><strong><%= formatCurrency(totalAmount) %></strong></td>
                        </tr>
                    </tbody>
                </table>

                <form action="/invoices/create" method="POST" style="max-width: 500px; margin-top: 2rem;">
                    <input type="hidden" name="booking_id" value="<%= booking.booking_id %>">
                    <input type="hidden" name="room_charge" value="<%= roomCharge %>">
                    <input type="hidden" name="service_charge" value="<%= serviceCharge %>">
                    <input type="hidden" name="tax" value="<%= tax %>">
                    <input type="hidden" name="total_amount" value="<%= totalAmount %>">

                    <div class="form-group">
                        <label for="discount">Giảm Giá:</label>
                        <input type="number" id="discount" name="discount" class="form-control" value="0" min="0" step="10000">
                    </div>

                    <div class="form-group">
                        <label for="paid_amount">Số Tiền Thanh Toán:</label>
                        <input type="number" id="paid_amount" name="paid_amount" class="form-control" value="<%= totalAmount %>" min="0" step="10000">
                    </div>

                    <div class="form-group">
                        <label for="payment_method">Phương Thức Thanh Toán:</label>
                        <select id="payment_method" name="payment_method" class="form-control">
                            <option value="cash">Tiền Mặt</option>
                            <option value="card">Thẻ</option>
                            <option value="transfer">Chuyển Khoản</option>
                            <option value="other">Khác</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="notes">Ghi Chú:</label>
                        <textarea id="notes" name="notes" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Tạo Hóa Đơn</button>
                        <a href="/bookings/<%= booking.booking_id %>" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
