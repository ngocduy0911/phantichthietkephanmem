<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hóa Đơn #<%= invoice.invoice_id %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        @media print {
            .no-print { display: none; }
            body { background: white; }
            .card { box-shadow: none; border: none; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <%- include('../partials/header') %>
        <%- include('../partials/nav') %>
    </div>

    <div class="main-content">
        <div class="container">
            <div class="card">
                <div class="card-header no-print">
                    <div class="d-flex justify-between align-center">
                        <h2>📄 Hóa Đơn #<%= invoice.invoice_id %></h2>
                        <div class="d-flex gap-2">
                            <% if (invoice.payment_status !== 'paid') { %>
                                <a href="/invoices/<%= invoice.invoice_id %>/payment" class="btn btn-success">Thanh Toán</a>
                            <% } %>
                            <button onclick="window.print()" class="btn btn-primary">In Hóa Đơn</button>
                            <a href="/invoices" class="btn btn-secondary">Quay Lại</a>
                        </div>
                    </div>
                </div>

                <div style="text-align: center; margin-bottom: 2rem;">
                    <h1 style="margin: 0; color: #2c3e50;">🏨 KHÁCH SẠN ABC</h1>
                    <p style="margin: 0.5rem 0;">Địa chỉ: 123 Đường XYZ, Quận 1, TP.HCM</p>
                    <p style="margin: 0;">Điện thoại: 0123-456-789 | Email: info@hotel.com</p>
                    <h2 style="margin-top: 1.5rem; color: #3498db;">HÓA ĐƠN THANH TOÁN</h2>
                    <p style="margin: 0.5rem 0;"><strong>Số:</strong> <%= invoice.invoice_id %> | <strong>Ngày:</strong> <%= moment(invoice.invoice_date).format('DD/MM/YYYY HH:mm') %></p>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
                    <div>
                        <h3>Thông Tin Khách Hàng</h3>
                        <p><strong>Họ Tên:</strong> <%= invoice.customer_name %></p>
                        <p><strong>CMND/CCCD:</strong> <%= invoice.id_card %></p>
                        <p><strong>Số Điện Thoại:</strong> <%= invoice.phone %></p>
                    </div>
                    <div>
                        <h3>Thông Tin Booking</h3>
                        <p><strong>Mã Booking:</strong> #<%= invoice.booking_id %></p>
                        <p><strong>Phòng:</strong> <%= invoice.room_number %> - <%= invoice.type_name %></p>
                        <p><strong>Check-in:</strong> <%= moment(invoice.check_in_date).format('DD/MM/YYYY') %></p>
                        <p><strong>Check-out:</strong> <%= moment(invoice.check_out_date).format('DD/MM/YYYY') %></p>
                    </div>
                </div>

                <h3>Chi Tiết Thanh Toán</h3>
                <table class="table" style="margin-bottom: 2rem;">
                    <thead>
                        <tr>
                            <th>Mô Tả</th>
                            <th style="text-align: right;">Thành Tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Tiền Phòng</td>
                            <td style="text-align: right;"><%= formatCurrency(invoice.room_charge) %></td>
                        </tr>
                        <% if (bookingServices.length > 0) { %>
                            <% bookingServices.forEach(service => { %>
                                <tr>
                                    <td><%= service.service_name %> (<%= service.quantity %> <%= service.unit %>)</td>
                                    <td style="text-align: right;"><%= formatCurrency(service.total_price) %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                        <tr>
                            <td>Tổng Tiền Dịch Vụ</td>
                            <td style="text-align: right;"><%= formatCurrency(invoice.service_charge) %></td>
                        </tr>
                        <tr>
                            <td>Thuế VAT (10%)</td>
                            <td style="text-align: right;"><%= formatCurrency(invoice.tax) %></td>
                        </tr>
                        <% if (invoice.discount > 0) { %>
                            <tr>
                                <td>Giảm Giá</td>
                                <td style="text-align: right; color: #e74c3c;">-<%= formatCurrency(invoice.discount) %></td>
                            </tr>
                        <% } %>
                        <tr style="background-color: #f8f9fa; font-size: 1.1rem;">
                            <td><strong>TỔNG CỘNG:</strong></td>
                            <td style="text-align: right; color: #27ae60;"><strong><%= formatCurrency(invoice.total_amount) %></strong></td>
                        </tr>
                        <tr>
                            <td>Đã Thanh Toán</td>
                            <td style="text-align: right;"><%= formatCurrency(invoice.paid_amount) %></td>
                        </tr>
                        <tr style="font-size: 1.1rem;">
                            <td><strong>Còn Lại:</strong></td>
                            <td style="text-align: right; color: <%= (invoice.total_amount - invoice.paid_amount) > 0 ? '#e74c3c' : '#27ae60' %>;"><strong><%= formatCurrency(invoice.total_amount - invoice.paid_amount) %></strong></td>
                        </tr>
                    </tbody>
                </table>

                <div style="margin-top: 2rem;">
                    <p><strong>Phương Thức Thanh Toán:</strong>
                        <% if (invoice.payment_method === 'cash') { %>Tiền Mặt
                        <% } else if (invoice.payment_method === 'card') { %>Thẻ
                        <% } else if (invoice.payment_method === 'transfer') { %>Chuyển Khoản
                        <% } else { %>Khác<% } %>
                    </p>
                    <p><strong>Trạng Thái:</strong>
                        <% if (invoice.payment_status === 'paid') { %>
                            <span class="badge badge-success">Đã Thanh Toán</span>
                        <% } else if (invoice.payment_status === 'partial') { %>
                            <span class="badge badge-warning">Thanh Toán 1 Phần</span>
                        <% } else { %>
                            <span class="badge badge-danger">Chưa Thanh Toán</span>
                        <% } %>
                    </p>
                    <% if (invoice.notes) { %>
                        <p><strong>Ghi Chú:</strong> <%= invoice.notes %></p>
                    <% } %>
                    <p><strong>Nhân Viên Tạo:</strong> <%= invoice.created_by_name || 'Hệ thống' %></p>
                </div>

                <div style="margin-top: 3rem; text-align: center;">
                    <p style="font-style: italic;">Cảm ơn quý khách đã sử dụng dịch vụ của chúng tôi!</p>
                    <p style="font-style: italic;">Hẹn gặp lại quý khách!</p>
                </div>
            </div>
        </div>
    </div>

    <div class="no-print">
        <%- include('../partials/footer') %>
    </div>
</body>
</html>
